                                "component_name": "DuckDuckGo",
                                "name": "WebSearch",
                                "params": {
                                    "top_n": 5
                                }
                            }
                        ],
                        "topPEnabled": true,
                        "top_p": 0.85,
                        "user_prompt": "",
                        "visual_files_var": ""
                    }
                },
                "upstream": ["VariableAggregator:QAAggregator"]
            },
